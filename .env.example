NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Required for server-only admin actions such as inviting students.
# Never expose this key in NEXT_PUBLIC_* variables.

# Mux video uploads and webhooks
MUX_TOKEN_ID=your-mux-token-id
MUX_TOKEN_SECRET=your-mux-token-secret
MUX_WEBHOOK_SECRET=your-mux-webhook-signing-secret
MUX_GENERATED_SUBTITLE_LANGUAGE_CODE=nl
MUX_GENERATED_SUBTITLE_NAME=Nederlands (auto)

# Internal transcription worker endpoint auth
TRANSCRIPTION_WORKER_SECRET=your-long-random-worker-secret

# Optional production app URL, for example Netlify/Vercel.
# NEXT_PUBLIC_SITE_URL=https://jouw-domein.com

# Project Speed: optional read-only browser checks for a dedicated test student.
# Never use a real student's account here.
E2E_EMAIL=test-student@example.com
E2E_PASSWORD=use-a-dedicated-test-password
# E2E_BASE_URL=https://coachedbycourse.netlify.app
# E2E_ALLOW_MUTATIONS=false
# PERF_RUNS=5

# Project Speed: use the single-roundtrip student dashboard read model.
# Keep off until the matching Supabase migration has been applied.
# PROJECT_SPEED_DASHBOARD_RPC=off
# PROJECT_SPEED_MODULES_RPC=off
# PROJECT_SPEED_STREAM_PROTECTED_SHELL=off
# PROJECT_SPEED_DEFER_LESSON_MUX=off
# PROJECT_SPEED_LOCAL_AUTH_CLAIMS=off
